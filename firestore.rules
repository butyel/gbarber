rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Barbearias: each user owns their own
    match /barbearias/{barbeiroId} {
      allow read, write: if request.auth != null && request.auth.uid == barbeiroId;
      
      // All subcollections inside a barbearia
      match /{collection}/{docId} {
        allow read, write: if request.auth != null && request.auth.uid == barbeiroId;
      }
    }
    
    // Leads remain open for creation
    match /leads/{lead} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}