rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Users can only read/write their own document
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    
    // Barbearias: owner has full access, public can read basic info
    match /barbearias/{ownerId} {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == ownerId;
      
      // Barbeiros: allow reading for login check and scheduling
      match /barbeiros/{barbeiroId} {
        allow read: if true;
        allow write: if request.auth != null && request.auth.uid == ownerId;
      }

      // Atendimentos: allow public read/write for scheduling
      match /atendimentos/{atendimentoId} {
        allow read, write: if true;
      }

      // Clientes: allow public creation during scheduling
      match /clientes/{clienteId} {
        allow read: if true;
        allow create: if true;
        allow update, delete: if request.auth != null && request.auth.uid == ownerId;
      }

      // Other subcollections (servicos, produtos, etc)
      match /{collection}/{docId} {
        allow read: if true; // Allow public view for scheduling
        allow write: if request.auth != null && request.auth.uid == ownerId;
      }
    }
    
    // Leads remain open for creation
    match /leads/{lead} {
      allow create: if true;
      allow read, update, delete: if false;
    }
  }
}